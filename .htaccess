Options -Indexes
RewriteEngine On
RewriteBase /biz/

# ── Admin
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^admin(/.*)?$ admin/index.php [QSA,L]

# ── City subfolder: /cities/{slug}/*
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^cities/([^/]+)(/.*)?$ cities/$1/index.php [QSA,L]

# ── Main landing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ index.php [QSA,L]
